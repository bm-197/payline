DATABASE_URL="postgres://payline:payline@localhost:5433/payline"

# Email transport: "console" (default) or "resend".
EMAIL_TRANSPORT="console"

# Inngest (durable reminders). For local dev set INNGEST_DEV=1 and run the Inngest
# dev server with: pnpm dev:inngest . Production sets the keys instead of INNGEST_DEV.
INNGEST_DEV="1"
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# Stripe (test mode for v0.1). Real values go in .env (gitignored), never here.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Better Auth. Generate a real secret per environment; keep it in .env, not here.
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# Base URL used to build hosted invoice + Checkout return links.
APP_URL="http://localhost:3000"
